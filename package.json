{
  "name": "@jsynowiec/mcp-server-nbp-api",
  "version": "0.1.0",
  "description": "MCP server for the NBP (National Bank of Poland) Web API: exchange rates and gold prices.",
  "license": "MIT",
  "author": "Jakub Synowiec",
  "type": "module",
  "bin": {
    "mcp-server-nbp-api": "dist/index.js"
  },
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "imports": {
    "#/*": {
      "bun": "./src/*",
      "default": "./dist/*"
    },
    "#tests/*": "./tests/*"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "format": "prettier --write src tests",
    "fmtcheck": "prettier --check src tests",
    "check-types": "tsc --noEmit",
    "test": "bun test",
    "dev:test": "bun test --watch",
    "prebuild": "bun run lint && bun run check-types && bun run fmtcheck && bun run test",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@toon-format/toon": "^2.3.0",
    "lru-cache": "^11.5.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^24.13.1",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jsynowiec/mcp-server-nbp-api.git"
  },
  "bugs": {
    "url": "https://github.com/jsynowiec/mcp-server-nbp-api/issues"
  },
  "homepage": "https://github.com/jsynowiec/mcp-server-nbp-api#readme",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "nbp",
    "exchange-rates",
    "gold-prices",
    "pln"
  ]
}
